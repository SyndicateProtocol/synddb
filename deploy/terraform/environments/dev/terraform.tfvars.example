# SyndDB Dev Environment Configuration
# Copy this file to terraform.tfvars and customize for your project

# Required: GCP Project
project_id = "your-gcp-project-id"

# Region and zone
region = "us-central1"
zone   = "us-central1-a"

# Container images (from Artifact Registry)
sequencer_image = "us-central1-docker.pkg.dev/your-project/synddb/sequencer:latest"
validator_image = "us-central1-docker.pkg.dev/your-project/synddb/validator:latest"

# Storage
gcs_bucket_name = "your-project-synddb-dev"
gcs_prefix      = "sequencer"

# Instance configuration (dev defaults)
sequencer_machine_type = "n2d-standard-2"
validator_machine_type = "n2d-standard-2"
use_spot_instances     = true   # Cost savings for dev
use_debug_images       = true   # SSH access for debugging

# Auto-cleanup old data in dev
lifecycle_delete_age_days = 7

# Artifact Registry (optional, for IAM bindings)
# artifact_registry_location   = "us-central1"
# artifact_registry_repository = "synddb"

# TEE Bootstrap (usually disabled for dev)
enable_key_bootstrap = false

# Proof service (requires GPU quota)
deploy_proof_service = false
# proof_service_image = "us-central1-docker.pkg.dev/your-project/synddb/proof-service:latest"

# SSH access for debugging (add your IP)
# allowed_ssh_ranges = ["YOUR_IP/32"]

# Labels
labels = {
  environment = "dev"
  managed-by  = "terraform"
  project     = "synddb"
}
