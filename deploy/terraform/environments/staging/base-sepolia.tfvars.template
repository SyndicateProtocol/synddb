# SyndDB Staging Environment - Base Sepolia
#
# This template includes deployed contract addresses for the price oracle example.
# Fill in the private values marked with TODO and rename to terraform.tfvars
#
# =============================================================================
# DEPLOYED CONTRACTS (Base Sepolia - 2026-01-04)
# =============================================================================
#
# AttestationVerifier: 0x820Da95B935AEE0A73919630B1cBf6C431802886
# TeeKeyManager:       0xC47c31D85825670dE56F5770C3478b971DE6409e
# Bridge:              0x0828C7E50880bdC777647a5BD2fD0649A0cbFE35
# PriceOracle:         0x78dCB012BA4562E3226169B45DD393EbBbc07637
#
# Basescan: https://sepolia.basescan.org
#
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Project Configuration (PRIVATE - fill in your values)
# -----------------------------------------------------------------------------

# TODO: Your GCP project ID
project_id = "TODO_YOUR_GCP_PROJECT_ID"

region = "us-central1"
zone   = "us-central1-a"

# -----------------------------------------------------------------------------
# Container Images
# -----------------------------------------------------------------------------

sequencer_image     = "us-central1-docker.pkg.dev/synddb-infra/synddb/synddb-sequencer:edge"
proof_service_image = "us-central1-docker.pkg.dev/synddb-infra/synddb/proof-service:edge"
validator_image     = "us-central1-docker.pkg.dev/synddb-infra/synddb/price-oracle-validator:edge"

# -----------------------------------------------------------------------------
# Storage (PRIVATE - must be globally unique)
# -----------------------------------------------------------------------------

# TODO: Unique bucket name for batch storage
gcs_bucket_name = "TODO_YOUR_PROJECT-synddb-staging"

# -----------------------------------------------------------------------------
# Artifact Registry
# -----------------------------------------------------------------------------

artifact_registry_location   = "us-central1"
artifact_registry_repository = "synddb"

# -----------------------------------------------------------------------------
# Instance Configuration
# -----------------------------------------------------------------------------

sequencer_machine_type = "n2d-standard-2"
validator_machine_type = "n2d-standard-2"

# -----------------------------------------------------------------------------
# TEE Bootstrap Configuration (Base Sepolia)
# -----------------------------------------------------------------------------

tee_bootstrap = {
  key_manager_address = "0xC47c31D85825670dE56F5770C3478b971DE6409e"

  # TODO: RPC URL (use public or your own with API key)
  rpc_url = "https://sepolia.base.org"

  chain_id = 84532

  # TODO: Your attestation audience (must be unique per example)
  # Format: https://<your-domain>/<example-name>
  attestation_audience = "https://TODO_YOUR_DOMAIN/price-oracle"
}

# -----------------------------------------------------------------------------
# Bridge Signer Configuration
# -----------------------------------------------------------------------------

enable_bridge_signer    = true
bridge_contract_address = "0x0828C7E50880bdC777647a5BD2fD0649A0cbFE35"
bridge_chain_id         = 84532

# -----------------------------------------------------------------------------
# Batching Configuration
# -----------------------------------------------------------------------------

batch_max_messages   = 100
batch_flush_interval = "2s"

# -----------------------------------------------------------------------------
# Price Oracle Configuration
# -----------------------------------------------------------------------------

price_oracle_image            = "us-central1-docker.pkg.dev/synddb-infra/synddb/price-oracle:edge"
price_oracle_contract_address = "0x78dCB012BA4562E3226169B45DD393EbBbc07637"

price_oracle_config = {
  # TODO: API keys (optional - free tier works without)
  coingecko_api_key = ""
  cmc_api_key       = ""

  fetch_interval        = 60
  assets                = ["BTC", "ETH", "SOL"]
  chain_monitor_enabled = true
}

# -----------------------------------------------------------------------------
# Relayer Configuration (Optional - for gas funding)
# -----------------------------------------------------------------------------
# Uncomment and fill in to enable the relayer service

# relayer_image = "us-central1-docker.pkg.dev/synddb-infra/synddb/synddb-relayer:edge"
#
# relayer_config = {
#   rpc_url                = "https://sepolia.base.org"  # TODO: Use private RPC
#   chain_id               = 84532
#   key_manager_address    = "0xC47c31D85825670dE56F5770C3478b971DE6409e"
#   treasury_address       = "0xTODO_GAS_TREASURY_ADDRESS"
#   required_audience_hash = "0xTODO_KECCAK256_OF_AUDIENCE"
#   allowed_image_digests  = []  # TODO: Add image digests
# }

# -----------------------------------------------------------------------------
# Labels
# -----------------------------------------------------------------------------

labels = {
  environment = "staging"
  managed-by  = "terraform"
  project     = "synddb"
  chain       = "base-sepolia"
}

# =============================================================================
# USAGE
# =============================================================================
#
# Contracts are already deployed. To deploy infrastructure:
#
#   1. Copy this template:
#      cp base-sepolia.tfvars.template terraform.tfvars
#
#   2. Fill in TODO values (project_id, gcs_bucket_name, attestation_audience)
#
#   3. Deploy:
#      terraform init
#      terraform plan
#      terraform apply
#
#   4. Test end-to-end:
#      cast send --rpc-url https://sepolia.base.org \
#          0x78dCB012BA4562E3226169B45DD393EbBbc07637 \
#          "requestPrice(string,uint256)" "BTC" 0
#
# See README.md for full deployment guide.
# =============================================================================
