# SyndDB Production Environment Configuration
# Copy this file to terraform.tfvars and customize for your deployment

# Required: GCP Project
project_id = "your-gcp-project-id"

# Region and zone
region = "us-central1"
zone   = "us-central1-a"

# Container images (use pinned versions for production)
sequencer_image     = "us-central1-docker.pkg.dev/your-project/synddb/sequencer:v1.0.0"
validator_image     = "us-central1-docker.pkg.dev/your-project/synddb/validator:v1.0.0"
proof_service_image = "us-central1-docker.pkg.dev/your-project/synddb/proof-service:v1.0.0"

# Storage
gcs_bucket_name = "your-project-synddb-prod"

# Instance configuration (production sizing)
sequencer_machine_type = "n2d-standard-4"
validator_machine_type = "n2d-standard-4"
validator_count        = 1

# Artifact Registry (required for IAM bindings)
artifact_registry_location   = "us-central1"
artifact_registry_repository = "synddb"

# TEE Bootstrap (required for production)
# Set to null to disable, or provide the object to enable
tee_bootstrap = {
  key_manager_address  = "0x..."  # Deployed TeeKeyManager contract
  rpc_url              = "https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY"
  chain_id             = 1
  attestation_audience = "https://synddb.your-domain.com"
}

# Bridge signer (optional, for cross-chain withdrawals)
enable_bridge_signer    = false
# bridge_contract_address = "0x..."
# bridge_chain_id         = 1

# Batching (production tuning)
batch_max_messages   = 100
batch_flush_interval = "2s"

# Labels
labels = {
  environment = "prod"
  managed-by  = "terraform"
  project     = "synddb"
}
