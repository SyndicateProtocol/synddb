# SyndDB Local Development Environment
#
# Quick start:
#   1. Copy this file: cp .env.local.example .env
#   2. Deploy contracts: ./scripts/deploy-local.sh
#   3. Run sequencer: cargo run -p synddb-sequencer
#   4. Run validator: cargo run -p synddb-validator -- --sequencer-url http://localhost:8433
#
# These values work with Anvil's default accounts and deterministic deployment addresses.

# Anvil RPC
ETH_RPC_URL=http://127.0.0.1:8545

# Chain ID (Anvil default)
BRIDGE_CHAIN_ID=31337

# Deterministic contract addresses (from ./scripts/deploy-local.sh)
# These are CREATE addresses from deploying with Anvil Account 0
WETH_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
BRIDGE_CONTRACT=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
PRICE_ORACLE_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# Anvil Account 0 - Admin (DO NOT USE IN PRODUCTION)
ADMIN_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Anvil Account 1 - Sequencer (DO NOT USE IN PRODUCTION)
SEQUENCER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
SEQUENCER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Sequencer signing key (can use any of the Anvil private keys)
SIGNING_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Database paths (local development)
DATABASE_PATH=./data/sequencer.db
VALIDATOR_DATABASE_PATH=./data/validator.db

# Sequencer config
BIND_ADDRESS=127.0.0.1:8433

# Validator config (when running validator)
SEQUENCER_URL=http://127.0.0.1:8433
# SEQUENCER_PUBKEY will be shown in sequencer logs at startup
