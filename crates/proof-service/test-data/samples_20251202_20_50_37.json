  "instructions": {
    "summary": "Use these samples to develop and test SP1 on-chain attestation verification",
    "verification_steps": [
      "1. Parse the JWT: split raw_token by '.' into [header, payload, signature]",
      "2. Decode header and payload from base64url",
      "3. Find the signing key in jwks.keys where kid matches header.kid",
      "4. Verify RS256 signature: RSA_PKCS1_SHA256(signing_input, signature, public_key)",
      "5. Validate claims: iss, aud, exp, iat",
      "6. Check TEE claims: secboot, swname, image_digest"
    ],
    "important_claims": [
      "iss - must be https://confidentialcomputing.googleapis.com",
      "aud - must match expected audience",
      "exp - token expiration (Unix timestamp)",
      "secboot - secure boot enabled (should be true)",
      "swname - should be CONFIDENTIAL_SPACE",
      "submods.container.image_digest - container image hash"
    ]
  }
