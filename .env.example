# SyndDB Production Environment Configuration
#
# This file documents environment variables for PRODUCTION deployments.
# For local development, use `just dev` - no .env file needed!
#
# To customize local dev, create .env with overrides (it's gitignored).

# =============================================================================
# Required - Sequencer
# =============================================================================

# Private key for signing messages (hex, without 0x prefix)
SIGNING_KEY=

# Bind address for HTTP API
BIND_ADDRESS=0.0.0.0:8433

# SQLite database path
DATABASE_PATH=/data/sequencer.db

# =============================================================================
# Required - Validator
# =============================================================================

# Sequencer's public key for signature verification (hex)
SEQUENCER_PUBKEY=

# Sequencer URL to fetch messages from
SEQUENCER_URL=https://sequencer.example.com

# Validator database paths
DATABASE_PATH=/data/validator.db
STATE_DB_PATH=/data/validator_state.db
PENDING_CHANGESETS_DB_PATH=/data/pending_changesets.db

# =============================================================================
# Optional - Bridge Signer (Validator)
# =============================================================================

# Enable bridge signing
BRIDGE_SIGNER=false

# Bridge contract address
BRIDGE_CONTRACT=0x...

# Chain ID for bridge transactions
BRIDGE_CHAIN_ID=1

# Private key for bridge signing (hex, without 0x prefix)
BRIDGE_SIGNING_KEY=

# =============================================================================
# Optional - Logging
# =============================================================================

# Log level: error, warn, info, debug, trace
RUST_LOG=info
