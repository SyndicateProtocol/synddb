# SyndDB Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database Configuration
SYNDDB_DATABASE_PATH=./data/synddb.sqlite
SYNDDB_DATABASE_POOL_SIZE=16

# Node Role (sequencer, replica, validator)
SYNDDB_ROLE=sequencer

# Blockchain Configuration
SYNDDB_CHAIN_RPC_URL=https://rpc.syndicate.io
SYNDDB_CHAIN_CONTRACT_ADDRESS=0x...
# WARNING: Never commit private keys! Use secure secret management in production
SYNDDB_CHAIN_PRIVATE_KEY=0x...

# Gas configuration (optional - Alloy will estimate if not set)
SYNDDB_CHAIN_GAS_MULTIPLIER=1.2  # 20% buffer on gas estimates
# SYNDDB_CHAIN_MAX_PRIORITY_FEE_PER_GAS=2  # Optional: Max priority fee in gwei
# SYNDDB_CHAIN_MAX_FEE_PER_GAS=100  # Optional: Max fee per gas in gwei

# Transaction confirmation settings
SYNDDB_CHAIN_CONFIRMATIONS=1
SYNDDB_CHAIN_POLL_INTERVAL_MS=1000

# Storage Configuration
SYNDDB_STORAGE_PROVIDER=ipfs
SYNDDB_STORAGE_IPFS_GATEWAY=https://ipfs.io
SYNDDB_STORAGE_IPFS_API_ENDPOINT=http://localhost:5001

# Sequencer Configuration (only for sequencer nodes)
SYNDDB_SEQUENCER_BATCH_SIZE=1000
SYNDDB_SEQUENCER_BATCH_TIMEOUT_MS=100
SYNDDB_SEQUENCER_PUBLISH_INTERVAL_MS=1000

# Replica Configuration (only for replica nodes)
SYNDDB_REPLICA_SYNC_INTERVAL_MS=500
SYNDDB_REPLICA_QUERY_PORT=3000
