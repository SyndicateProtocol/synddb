# SyndDB Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database Configuration
SYNDDB_DATABASE_PATH=./data/synddb.sqlite

# Connection pool size - how many simultaneous database connections
# SYNDDB_DATABASE_POOL_SIZE=4  # Default: 4 (optimal for single-writer sequencer)
#
# Trade-offs:
# - Lower (2-4): Optimal for sequencer. SQLite serializes writes anyway.
#   ✅ Less memory overhead (each connection holds cache)
#   ✅ Sufficient for 1 writer + concurrent readers
#   ❌ May bottleneck if many concurrent reads
#
# - Higher (8-16): Better for read-heavy replicas serving many queries
#   ✅ More concurrent read capacity
#   ❌ Higher memory usage (connections × cache size)
#   ❌ Diminishing returns due to SQLite's write serialization

# SQLite Performance Tuning
# These settings control SQLite behavior - defaults are optimized for production
# Uncomment and adjust for development or specific performance requirements

# SYNDDB_DATABASE_JOURNAL_MODE=WAL  # WAL mode for concurrent reads (recommended)
# SYNDDB_DATABASE_SYNCHRONOUS=NORMAL  # NORMAL=fast, FULL=safe but slow
# SYNDDB_DATABASE_CACHE_SIZE=-2000000  # Cache in KB (negative) - default 2GB
# SYNDDB_DATABASE_MMAP_SIZE=274877906944  # Memory map size - default 256GB

# Locking mode - IMPORTANT: affects concurrent access
# SYNDDB_DATABASE_LOCKING_MODE=EXCLUSIVE  # Production (best performance)
# SYNDDB_DATABASE_LOCKING_MODE=NORMAL     # Development (allows sqlite3 CLI access)
#
# Trade-offs:
# - EXCLUSIVE (default): Maximum performance, single process access only
#   ✅ Use in production for sequencer (single process)
#   ❌ Blocks external tools (sqlite3, backups, debuggers) while app runs
#
# - NORMAL: Allows concurrent access, slightly slower
#   ✅ Use in development to run sqlite3 CLI alongside app
#   ✅ Use if you need external monitoring/backup tools
#   ❌ Small performance penalty (~5-10%)

# Node Role (sequencer, replica)
SYNDDB_ROLE=sequencer

# Blockchain Configuration
SYNDDB_CHAIN_RPC_URL=https://rpc.syndicate.io
SYNDDB_CHAIN_CONTRACT_ADDRESS=0x...
# WARNING: Never commit private keys! Use secure secret management in production
SYNDDB_CHAIN_PRIVATE_KEY=0x...

# Gas configuration (optional caps - Alloy estimates gas automatically)
# Uncomment to set maximum fee caps for protection against gas price spikes
# SYNDDB_CHAIN_MAX_PRIORITY_FEE_PER_GAS=2  # Max priority fee in gwei (MEV protection)
# SYNDDB_CHAIN_MAX_FEE_PER_GAS=100  # Max total fee in gwei (spike protection)

# Transaction confirmation settings
SYNDDB_CHAIN_CONFIRMATIONS=1  # Blocks to wait (1=fast, 3+=secure)
SYNDDB_CHAIN_POLL_INTERVAL_MS=1000  # How often to check tx status

# Storage Configuration
SYNDDB_STORAGE_PROVIDER=ipfs
SYNDDB_STORAGE_IPFS_GATEWAY=https://ipfs.io
SYNDDB_STORAGE_IPFS_API_ENDPOINT=http://localhost:5001

# Sequencer Configuration (only for sequencer nodes)
SYNDDB_SEQUENCER_BATCH_SIZE=1000
SYNDDB_SEQUENCER_BATCH_TIMEOUT_MS=100
SYNDDB_SEQUENCER_PUBLISH_INTERVAL_MS=1000

# Replica Configuration (only for replica nodes)
SYNDDB_REPLICA_SYNC_INTERVAL_MS=500
SYNDDB_REPLICA_QUERY_PORT=3000
