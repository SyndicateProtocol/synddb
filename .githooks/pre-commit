#!/bin/bash
#
# Pre-commit hook to run formatters on staged files
#
# This script allows individual checks to fail gracefully - each check runs
# independently and all checks will be attempted even if some fail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get the root directory of the git repository
REPO_ROOT=$(git rev-parse --show-toplevel)

# Track if any files were formatted
FILES_FORMATTED=false

# Track failures
FAILED_CHECKS=0

echo -e "${BLUE}Running pre-commit checks...${NC}"

# ==========================
# Rust Formatting
# ==========================

# Get list of staged Rust files
STAGED_RUST_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)

if [ -n "$STAGED_RUST_FILES" ]; then
    echo -e "${YELLOW}Checking Rust formatting...${NC}"

    # Check if cargo is installed
    if ! command -v cargo &> /dev/null; then
        echo -e "${RED}✗ cargo is not installed or not in PATH${NC}"
        echo -e "${YELLOW}  Please install Rust: https://rustup.rs/${NC}"
        echo -e "${YELLOW}  Skipping Rust formatting check${NC}"
        FAILED_CHECKS=$((FAILED_CHECKS + 1))
    else
        # Run cargo fmt --check
        if cargo fmt --check > /dev/null 2>&1; then
            echo -e "${GREEN}✓ All Rust files are properly formatted${NC}"
        else
            echo -e "${YELLOW}Formatting Rust files...${NC}"
            if cargo fmt; then
                FILES_FORMATTED=true

                # Re-add the formatted files
                echo "$STAGED_RUST_FILES" | while IFS= read -r file; do
                    if [ -f "$file" ]; then
                        git add "$file"
                        echo -e "${GREEN}  ✓ Formatted and re-staged: $file${NC}"
                    fi
                done

                echo -e "${GREEN}✓ Rust files formatted and re-staged${NC}"
            else
                echo -e "${RED}✗ Failed to format Rust files${NC}"
                FAILED_CHECKS=$((FAILED_CHECKS + 1))
            fi
        fi
    fi
fi

# ==========================
# Solidity Formatting
# ==========================

# Get list of staged Solidity files
STAGED_SOL_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sol$' || true)

if [ -n "$STAGED_SOL_FILES" ]; then
    echo -e "${YELLOW}Checking Solidity formatting...${NC}"

    # Change to the contracts directory
    if ! cd "$REPO_ROOT/contracts" 2>/dev/null; then
        echo -e "${YELLOW}⚠ contracts directory not found, skipping Solidity formatting${NC}"
    else
        # Check if forge is installed
        if ! command -v forge &> /dev/null; then
            echo -e "${RED}✗ forge is not installed or not in PATH${NC}"
            echo -e "${YELLOW}  Please install Foundry: https://book.getfoundry.sh/getting-started/installation${NC}"
            echo -e "${YELLOW}  Skipping Solidity formatting check${NC}"
            FAILED_CHECKS=$((FAILED_CHECKS + 1))
            cd "$REPO_ROOT"
        else
            # Run forge fmt
            if forge fmt --check > /dev/null 2>&1; then
                echo -e "${GREEN}✓ All Solidity files are properly formatted${NC}"
                cd "$REPO_ROOT"
            else
                echo -e "${YELLOW}Formatting Solidity files...${NC}"
                if forge fmt; then
                    FILES_FORMATTED=true

                    # Re-add the formatted files (need to be relative to repo root)
                    cd "$REPO_ROOT"
                    echo "$STAGED_SOL_FILES" | while IFS= read -r file; do
                        if [ -f "$file" ]; then
                            git add "$file"
                            echo -e "${GREEN}  ✓ Formatted and re-staged: $file${NC}"
                        fi
                    done

                    echo -e "${GREEN}✓ Solidity files formatted and re-staged${NC}"
                else
                    echo -e "${RED}✗ Failed to format Solidity files${NC}"
                    FAILED_CHECKS=$((FAILED_CHECKS + 1))
                    cd "$REPO_ROOT"
                fi
            fi
        fi
    fi
fi

# Summary output
if [ -z "$STAGED_RUST_FILES" ] && [ -z "$STAGED_SOL_FILES" ]; then
    echo -e "${BLUE}No Rust or Solidity files staged, skipping formatting checks${NC}"
elif [ "$FILES_FORMATTED" = true ]; then
    echo ""
    echo -e "${YELLOW}⚠ Files were automatically formatted and re-staged${NC}"
    echo -e "${YELLOW}Review the changes with 'git diff --cached' before pushing${NC}"
fi

# Report final status
if [ "$FAILED_CHECKS" -gt 0 ]; then
    echo ""
    echo -e "${RED}✗ Pre-commit checks completed with $FAILED_CHECKS failure(s)${NC}"
    echo -e "${YELLOW}Some checks failed but the commit can proceed${NC}"
    echo -e "${YELLOW}Please review the errors above and fix them before pushing${NC}"
    exit 0
else
    echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
    exit 0
fi
