# SyndDB Contracts - Production Deployment
#
# For local development, use `just contracts::build` and `just deploy`.
# These variables are only needed for testnet/mainnet deployments.

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Admin address for deployed contracts
ADMIN_ADDRESS=0x...

# Sequencer address (authorized to submit messages)
SEQUENCER_ADDRESS=0x...
